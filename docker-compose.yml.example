services:
  hbbs:
    image: rustdesk/rustdesk-server:latest
    restart: unless-stopped
    command: hbbs -r hbbr:21117
    environment:
      ALWAYS_USE_RELAY: "Y"
    volumes:
      - rustdesk_server_data:/root
    ports:
      - "21115:21115"
      - "21116:21116"
      - "21116:21116/udp"
      - "21118:21118"

  hbbr:
    image: rustdesk/rustdesk-server:latest
    restart: unless-stopped
    command: hbbr
    volumes:
      - rustdesk_server_data:/root
    ports:
      - "21117:21117"
      - "21119:21119"

  postgres:
    image: postgres:15
    restart: always
    environment:
      POSTGRES_USER: rustdesk
      POSTGRES_PASSWORD: rustdesk123
      POSTGRES_DB: rustdesk
      TZ: "America/Cuiaba"
      PGTZ: "America/Cuiaba"
    volumes:
      - ./pgdata:/var/lib/postgresql/data
    ports:
      - "5432:5432"

  api:
    build: ./api
    depends_on:
      - postgres
    environment:
      DATABASE_URL: postgres://rustdesk:rustdesk123@postgres:5432/rustdesk
      JWT_SECRET: supersecretkey
      ID_SERVER: "seu-ip-aqui"
      RELAY_SERVER: "seu-ip-aqui"
      RUSTDESK_KEY: "sua-chave-publica-aqui"
      ADMIN_EMAIL: "administrador"
      ADMIN_PASSWORD: "tipref#2026"
      TZ: "America/Cuiaba"
    ports:
      - "3000:3000"
    volumes:
      - ./api:/app
      - /app/node_modules
      - rustdesk_server_data:/root:ro  # Use o mesmo volume que o hbbs/hbbr!

  frontend:
    build: ./frontend
    ports:
      - "8080:80"

volumes:
  rustdesk_server_data:
