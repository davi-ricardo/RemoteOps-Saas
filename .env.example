# Arquivo .env - Copie este arquivo para .env e preencha com seus valores!

# Credenciais do banco de dados PostgreSQL
POSTGRES_USER=rustdesk
POSTGRES_PASSWORD=rustdesk123
POSTGRES_DB=rustdesk

# Chave secreta para assinar tokens JWT (mude para algo seguro!)
JWT_SECRET=supersecretkey

# Configurações do RustDesk Server
ID_SERVER=seu-ip-aqui
RELAY_SERVER=seu-ip-aqui
RUSTDESK_KEY=sua-chave-publica-aqui

# Credenciais do usuário administrador do painel
ADMIN_EMAIL=administrador
ADMIN_PASSWORD=tipref#2026
